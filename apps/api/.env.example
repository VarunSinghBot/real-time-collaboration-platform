# Server Configuration
PORT=4000
GO_ENV=development

# Database Configuration
# Format: postgresql://username:password@host:port/database?sslmode=disable
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/collab_platform?sslmode=disable

# JWT Configuration
# Generate a secure secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-openssl-rand

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:4000/api/auth/google/callback
