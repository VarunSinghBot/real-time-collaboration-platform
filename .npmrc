# Hoist Tailwind CSS and related PostCSS plugins for Next.js compatibility
public-hoist-pattern[]=*tailwindcss*
public-hoist-pattern[]=*postcss*
public-hoist-pattern[]=*@tailwindcss*

# Ensure proper symlink behavior on Windows
symlink=true

# Strict peer dependencies (recommended for monorepos)
strict-peer-dependencies=false
